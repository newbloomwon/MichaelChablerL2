# Punkt Backend Environment Configuration
# Copy this file to .env and update with your actual values
# DO NOT commit the .env file to version control!

# Database Configuration
DATABASE_URL=postgresql+psycopg://punkt:punkt123@localhost:5432/punkt

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Secret - CHANGE THIS IN PRODUCTION!
# Use a strong, random secret (at least 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE-ME-IN-PRODUCTION-USE-STRONG-RANDOM-STRING

# CORS Origins - comma-separated or JSON array format
# For local development, both React dev server (3000) and Vite (5173) are enabled
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Optional: Environment name (development, staging, production)
# ENVIRONMENT=development
