# ─── ERCOT (Electric Reliability Council of Texas) ───────────────────────────
# Register + subscribe at: https://apiexplorer.ercot.com/products
# Docs: https://developer.ercot.com/applications/pubapi/user-guide/registration-and-authentication/
ERCOT_SUBSCRIPTION_KEY=YOUR_PRIMARY_SUBSCRIPTION_KEY   # from Profile → Subscriptions
ERCOT_SUBSCRIPTION_KEY_SECONDARY=YOUR_SECONDARY_KEY
ERCOT_USERNAME=YOUR_ERCOT_USERNAME                   # used to fetch short-lived ID token
ERCOT_PASSWORD=YOUR_ERCOT_PASSWORD
ERCOT_CLIENT_ID=YOUR_PUBLIC_CLIENT_ID                 # ERCOT B2C public client id
ERCOT_TOKEN_URL=https://ercotb2c.b2clogin.com/ercotb2c.onmicrosoft.com/B2C_1_PUBAPI-ROPC-FLOW/oauth2/v2.0/token
ERCOT_FREQUENCY_ENDPOINT=
ERCOT_FREQUENCY_URL=https://www.ercot.com/content/cdr/html/real_time_system_conditions.html
ERCOT_BASE_URL=https://api.ercot.com/api/public-reports

# ─── ISO-NE (ISO New England) ────────────────────────────────────────────────
# Register at: https://webservices.iso-ne.com/
# Docs: https://www.iso-ne.com/markets-operations/settlements/iso-ne-information-exchange-platform/
ISONE_USERNAME=YOUR_ISONE_USERNAME
ISONE_PASSWORD=YOUR_ISONE_PASSWORD
ISONE_BASE_URL=https://webservices.iso-ne.com/api/v1.1

# ─── App Settings ────────────────────────────────────────────────────────────
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
